# Configuración de PostgreSQL
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=shopping_list
POSTGRES_PORT=5432
ENVIRONMENT=local

# URL de Supabase (Usada solo si ENVIRONMENT=supabase)
SUPABASE_DATABASE_URI=postgresql://postgres:[YOUR-PASSWORD]@db.endhanscuwkspqgwitda.supabase.co:5432/postgres

# Seguridad JWT
# Generar una clave segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TU_LLAVE_SECRETA_GENERADA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configuración de Email / SMTP (Gmail)
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion_gmail
EMAILS_FROM_EMAIL=tu_correo@gmail.com
EMAILS_FROM_NAME="ShopList Pro"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# URL del Frontend (Para enlaces de verificación/reset)
FRONTEND_URL=http://localhost:5173

# Orígenes de CORS permitidos (separados por coma)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost,http://127.0.0.1:5173
